// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

/// A standalone dimension entity, e.g. "2.5mg", "5mg", "10mg"
/// Multiple products from different brands can share the same dimension.
model Dimension {
  id        String    @id @default(cuid())
  label     String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

/// Product = brand name + dimension + unit price
/// e.g. { name: "Ozempic", dimension: { label: "2.5mg" }, unitPrice: 150 }
/// e.g. { name: "Wegovy",  dimension: { label: "2.5mg" }, unitPrice: 200 }
model Product {
  id          String     @id @default(cuid())
  name        String
  dimensionId String
  dimension   Dimension  @relation(fields: [dimensionId], references: [id])
  unitPrice   Float
  saleItems   SaleItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Stock back-relations (additive — no schema changes to existing columns)
  stockLines   StockLine[]
  reservations StockReservation[]
  stockEvents  StockEvent[]

  @@unique([name, dimensionId])
}

model Sale {
  id             String         @id @default(cuid())
  date           DateTime       @db.Date
  clientName     String
  phone          String?
  address        String?
  deliveryStatus DeliveryStatus @default(NOT_DELIVERED)
  paymentStatus  PaymentStatus  @default(NOT_PAID)
  comments       String?
  highlightColor String?
  items          SaleItem[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Stock back-relation (additive)
  stockEvents StockEvent[]
}

/// Each item on a sale references a Product (which carries its Dimension).
/// totalPrice is NOT stored — always computed as quantity * product.unitPrice.
model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float?

  // Stock back-relation (additive)
  reservation StockReservation?
}

enum DeliveryStatus {
  NOT_DELIVERED
  DELIVERED
}

enum PaymentStatus {
  NOT_PAID
  WAITING_BANK_CONFIRMATION
  PAID
}

model ProductAlias {
  id        String   @id @default(cuid())
  alias     String   @unique
  name      String
  createdAt DateTime @default(now())
}

// ─── Stock Module Models ──────────────────────────────────────────────────────

/// A physical or virtual location that holds inventory (warehouse, person, van, etc.)
model Storage {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stockLines   StockLine[]
  stockEvents  StockEvent[]
  reservations StockReservation[]
}

/// Current quantity snapshot for a (product, storage) pair.
/// quantity is NEVER negative. Available = quantity - SUM(reservations).
model StockLine {
  id        String  @id @default(cuid())
  storageId String
  productId String
  quantity  Int     @default(0)

  storage Storage @relation(fields: [storageId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([storageId, productId])
}

/// Immutable audit log — never updated or deleted after creation.
model StockEvent {
  id            String         @id @default(cuid())
  type          StockEventType
  storageId     String
  productId     String
  delta         Int /// positive = increase, negative = decrease
  quantityAfter Int /// snapshot of StockLine.quantity after this event
  notes         String?
  saleId        String?
  createdAt     DateTime       @default(now())

  storage Storage @relation(fields: [storageId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  sale    Sale?   @relation(fields: [saleId], references: [id], onDelete: SetNull)
}

/// A reservation ties a SaleItem to a source storage.
/// Lifecycle: created when item added to sale → deleted when item removed, sale deleted, or sale delivered.
model StockReservation {
  id         String   @id @default(cuid())
  saleItemId String   @unique /// 1-to-1: one reservation per SaleItem
  storageId  String
  productId  String
  quantity   Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  saleItem SaleItem @relation(fields: [saleItemId], references: [id], onDelete: Cascade)
  storage  Storage  @relation(fields: [storageId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])
}

enum StockEventType {
  COUNT /// Physical inventory count (sets absolute value)
  TRANSFER_IN /// Goods arrived at this storage
  TRANSFER_OUT /// Goods left this storage
  SALE_DELIVERY /// Auto-decrease when sale marked as DELIVERED
}
